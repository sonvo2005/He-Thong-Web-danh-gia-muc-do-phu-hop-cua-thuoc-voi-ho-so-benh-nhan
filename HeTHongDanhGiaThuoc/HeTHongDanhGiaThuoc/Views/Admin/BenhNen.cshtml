@model IEnumerable<BenhNen>

@{
    ViewData["Title"] = "Quản Lý Bệnh Nền";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold text-primary mb-0">
        <i class="fas fa-heartbeat me-2"></i>Quản Lý Bệnh Nền
    </h4>
</div>

<div class="row">
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-warning text-dark py-3">
                <h6 class="mb-0">
                    <i class="fas fa-plus me-2"></i>Thêm bệnh nền mới
                </h6>
            </div>

            <div class="card-body">
                <form asp-action="ThemBenhNen" method="post">
                    @Html.AntiForgeryToken()

                    <div class="input-group">
                        <input type="text" name="tenBenhNen" class="form-control"
                               placeholder="Tên bệnh nền (VD: Tăng huyết áp)" required />

                        <button type="submit" class="btn btn-warning text-dark">
                            <i class="fas fa-plus me-1"></i>Thêm
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-bold">
                    <i class="fas fa-list me-2 text-warning"></i>
                    Danh sách bệnh nền (@Model.Count() bệnh nền)
                </h6>
            </div>

            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Mã</th>
                            <th>Tên bệnh nền</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.MaBenhNen</td>

                                <td class="fw-semibold">
                                    @item.TenBenhNen
                                </td>

                                <td class="text-center">
                                    <form asp-action="XoaBenhNen" asp-route-id="@item.MaBenhNen" method="post"
                                          class="d-inline" onsubmit="return confirm('Xóa bệnh nền này?')">

                                        @Html.AntiForgeryToken()

                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>
        </div>
    </div>
</div>