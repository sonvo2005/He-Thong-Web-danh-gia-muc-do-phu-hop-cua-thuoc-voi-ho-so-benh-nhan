@model IEnumerable<NguoiDung>
@{
    ViewData["Title"] = "Quản Lý Người Dùng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold text-primary mb-0">
        <i class="fas fa-users me-2"></i>Quản Lý Người Dùng
    </h4>
    <a asp-action="TaoNguoiDung" class="btn btn-primary">
        <i class="fas fa-user-plus me-1"></i>Thêm người dùng
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Họ tên</th>
                    <th>Tên đăng nhập</th>
                    <th>Email</th>
                    <th>Điện thoại</th>
                    <th>Vai trò</th>
                    <th>Ngày tạo</th>
                    <th>Trạng thái</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-semibold">@item.HoTen</td>
                        <td><code>@item.TenDangNhap</code></td>
                        <td class="text-muted">@item.Email</td>
                        <td class="text-muted">@item.SoDienThoai</td>
                        <td>
                            @{
                                string roleColor = item.VaiTro?.TenVaiTro switch {
                                    "Admin" => "bg-danger",
                                    "Bác sĩ" => "bg-primary",
                                    "Dược sĩ" => "bg-success",
                                    _ => "bg-secondary"
                                };
                            }
                            <span class="badge @roleColor">@item.VaiTro?.TenVaiTro</span>
                        </td>
                        <td class="text-muted">@item.NgayTao.ToString("dd/MM/yyyy")</td>
                        <td>
                            <span class="badge @(item.TrangThaiHoatDong ? "bg-success" : "bg-secondary")">
                                @(item.TrangThaiHoatDong ? "Hoạt động" : "Đã khóa")
                            </span>
                        </td>
                        <td class="text-center">
                            <a asp-action="SuaNguoiDung" asp-route-id="@item.MaNguoiDung"
                               class="btn btn-sm btn-outline-warning" title="Sửa">
                                <i class="fas fa-edit"></i>
                            </a>
                            @if (item.TenDangNhap != User.Identity?.Name)
                            {
                                <form asp-action="XoaNguoiDung" asp-route-id="@item.MaNguoiDung" method="post"
                                      class="d-inline" onsubmit="return confirm('Xác nhận xóa người dùng này?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
