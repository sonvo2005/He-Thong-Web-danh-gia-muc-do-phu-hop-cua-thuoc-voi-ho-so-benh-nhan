@model IEnumerable<TuongTacThuoc>
@{
    ViewData["Title"] = "Quản Lý Tương Tác Thuốc";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold text-primary mb-0">
        <i class="fas fa-exchange-alt me-2"></i>Quản Lý Tương Tác Thuốc
    </h4>
    <a asp-action="ThemTuongTac" class="btn btn-warning">
        <i class="fas fa-plus me-1"></i>Thêm tương tác
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Thuốc A</th>
                    <th class="text-center">↔</th>
                    <th>Thuốc B</th>
                    <th>Mức độ</th>
                    <th>Mô tả tương tác</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">
                        <i class="fas fa-pills fa-2x mb-2 d-block opacity-25"></i>
                        Chưa có tương tác thuốc nào được ghi nhận
                    </td></tr>
                }
                @foreach (var item in Model)
                {
                    string badgeClass = (item.MucDoNghiemTrong?.ToLower().Contains("nghiêm") == true ||
                                         item.MucDoNghiemTrong?.ToLower().Contains("cao") == true)
                                         ? "bg-danger" : item.MucDoNghiemTrong?.ToLower().Contains("trung") == true
                                         ? "bg-warning text-dark" : "bg-info text-dark";
                    <tr>
                        <td class="fw-semibold">@item.ThuocA?.TenThuoc</td>
                        <td class="text-center text-muted"><i class="fas fa-exchange-alt"></i></td>
                        <td class="fw-semibold">@item.ThuocB?.TenThuoc</td>
                        <td><span class="badge @badgeClass">@item.MucDoNghiemTrong</span></td>
                        <td class="text-muted small">
                            @(item.MoTaTuongTac?.Length > 80
                                ? item.MoTaTuongTac[..80] + "..."
                                : item.MoTaTuongTac)
                        </td>
                        <td class="text-center">
                            <form asp-action="XoaTuongTac" asp-route-id="@item.MaTuongTac" method="post"
                                  class="d-inline" onsubmit="return confirm('Xóa tương tác này?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
