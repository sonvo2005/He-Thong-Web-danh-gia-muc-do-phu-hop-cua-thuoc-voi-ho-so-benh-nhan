@model HoSoBenhNhan

@{
    ViewData["Title"] = "Thêm Hồ Sơ Bệnh Nhân";

    var hoatChats = ViewBag.HoatChats as List<HoatChat> ?? new();
    var benhNens = ViewBag.BenhNens as List<BenhNen> ?? new();
    var thuocs = ViewBag.Thuocs as List<Thuoc> ?? new();

}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary me-3">
        <i class="fas fa-arrow-left"></i>
    </a>

    <h4 class="fw-bold text-primary mb-0">
        <i class="fas fa-user-plus me-2"></i>
        Thêm Hồ Sơ Bệnh Nhân
    </h4>
</div>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <div class="row g-3">

        <!-- THÔNG TIN BỆNH NHÂN -->
        <div class="col-lg-6">

            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <i class="fas fa-user me-2"></i>
                    Thông Tin Bệnh Nhân
                </div>

                <div class="card-body">

                    <div class="mb-3">
                        <label asp-for="MaDinhDanhBenhNhan" class="form-label"></label>
                        <input asp-for="MaDinhDanhBenhNhan" class="form-control" />
                        <span asp-validation-for="MaDinhDanhBenhNhan" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="HoTen" class="form-label"></label>
                        <input asp-for="HoTen" class="form-control" />
                        <span asp-validation-for="HoTen" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="GioiTinh" class="form-label"></label>
                            <select asp-for="GioiTinh" class="form-select">
                                <option value="">-- Chọn giới tính --</option>
                                <option>Nam</option>
                                <option>Nữ</option>
                                <option>Khác</option>
                            </select>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="NgaySinh" class="form-label"></label>
                            <input asp-for="NgaySinh" type="date" class="form-control" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="NhomMau" class="form-label"></label>
                            <select asp-for="NhomMau" class="form-select">
                                <option value="">-- Chọn --</option>
                                <option>A+</option>
                                <option>A-</option>
                                <option>B+</option>
                                <option>B-</option>
                                <option>AB+</option>
                                <option>AB-</option>
                                <option>O+</option>
                                <option>O-</option>
                            </select>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label asp-for="ChieuCao" class="form-label"></label>
                            <input asp-for="ChieuCao" class="form-control" />
                        </div>

                        <div class="col-md-4 mb-3">
                            <label asp-for="CanNang" class="form-label"></label>
                            <input asp-for="CanNang" class="form-control" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="DiaChi" class="form-label"></label>
                        <textarea asp-for="DiaChi" class="form-control"></textarea>
                    </div>

                    <div class="mb-3">
                        <label asp-for="BenhHienTai" class="form-label"></label>
                        <textarea asp-for="BenhHienTai" class="form-control"></textarea>
                    </div>

                    <div class="mb-3">
                        <label asp-for="GhiChu" class="form-label"></label>
                        <textarea asp-for="GhiChu" class="form-control"></textarea>
                    </div>

                    @* <div class="mb-3">
                        <label asp-for="NgayTiepNhan" class="form-label"></label>
                        <input asp-for="NgayTiepNhan"
                               type="datetime-local"
                               class="form-control"
                               value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                    </div> *@

                </div>
            </div>

        </div>
        <!-- BỆNH NỀN + DỊ ỨNG -->
        <div class="col-lg-6">

            <div class="card shadow-sm border-0 mb-3">
                <div class="card-header bg-warning d-flex justify-content-between align-items-center">
                    <span>
                        <i class="fas fa-notes-medical me-2"></i>
                        Bệnh nền
                    </span>

                    <button type="button"
                            class="btn btn-sm btn-outline-dark"
                            onclick="addBenhNen()">
                        <i class="fas fa-plus"></i>
                    </button>
                </div>

                <div class="card-body" id="benhNenContainer">
                    <p id="emptyBenhNen" class="text-muted">
                        Chưa có bệnh nền
                    </p>
                </div>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-danger text-white d-flex justify-content-between align-items-center">

                    <span>
                        <i class="fas fa-allergies me-2"></i>
                        Dị ứng hoạt chất
                    </span>

                    <button type="button"
                            class="btn btn-sm btn-light"
                            onclick="addDiUng()">
                        <i class="fas fa-plus"></i>
                    </button>
                </div>

                <div class="card-body" id="diUngContainer">
                    <p id="emptyDiUng" class="text-muted">
                        Chưa có dị ứng
                    </p>
                </div>
            </div> 
       

        <!-- THUỐC DANG SỬ DỤNG -->
        <div class="card shadow-sm border-0 mt-3">

            <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">

                <span>
                    <i class="fas fa-pills me-2"></i>
                    Thuốc đang sử dụng
                </span>

                <button type="button" class="btn btn-sm btn-light" onclick="addThuocDangSuDung()">
                    <i class="fas fa-plus"></i>
                </button>

            </div>

            <div class="card-body" id="thuocContainer">

                <p id="emptyThuoc" class="text-muted">
                    Chưa có thuốc đang sử dụng
                </p>

            </div>

             </div>
        </div>
    </div>

    <div class="mt-4">
        <button type="submit" class="btn btn-primary btn-lg">
            <i class="fas fa-save me-2"></i>
            Lưu hồ sơ
        </button>
    </div>

</form>

