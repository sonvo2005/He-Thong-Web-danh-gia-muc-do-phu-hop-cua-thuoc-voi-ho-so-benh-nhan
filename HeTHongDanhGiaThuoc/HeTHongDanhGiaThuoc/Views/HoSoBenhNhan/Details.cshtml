@model HoSoBenhNhan
@{
    ViewData["Title"] = "Chi Tiết Bệnh Nhân";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div class="d-flex align-items-center">
        <a asp-action="Index" class="btn btn-outline-secondary me-3">
            <i class="fas fa-arrow-left"></i>
        </a>
        <h4 class="fw-bold text-primary mb-0">
            <i class="fas fa-hospital-user me-2"></i>@Model.HoTen
        </h4>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.MaBenhNhan" class="btn btn-warning">
            <i class="fas fa-edit me-1"></i>Chỉnh sửa
        </a>

        <a asp-controller="DanhGia" asp-action="Create" asp-route-maBenhNhan="@Model.MaBenhNhan"
           class="btn btn-primary">
            <i class="fas fa-clipboard-check me-1"></i>Đánh giá thuốc
        </a>
    </div>
</div>

<div class="row g-3">

    <div class="row g-3">

        <!-- THÔNG TIN CÁ NHÂN -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-primary text-white py-3">
                    <h6 class="mb-0">
                        <i class="fas fa-id-card me-2"></i>
                        Thông tin cá nhân
                    </h6>
                </div>

                <div class="card-body">
                    <table class="table table-sm table-borderless mb-0">

                        <tr>
                            <td class="text-muted fw-semibold">Mã định danh:</td>
                            <td>
                                <span class="badge bg-secondary">
                                    @Model.MaDinhDanhBenhNhan
                                </span>
                            </td>
                        </tr>

                        <tr>
                            <td class="text-muted fw-semibold">Họ tên:</td>
                            <td><strong>@Model.HoTen</strong></td>
                        </tr>

                        <tr>
                            <td class="text-muted fw-semibold">Giới tính:</td>
                            <td>@Model.GioiTinh</td>
                        </tr>

                        <tr>
                            <td class="text-muted fw-semibold">Ngày sinh:</td>
                            <td>@Model.NgaySinh?.ToString("dd/MM/yyyy")</td>
                        </tr>

                        <tr>
                            <td class="text-muted fw-semibold">Tuổi:</td>
                            <td>
                                @(Model.Tuoi.HasValue
                                    ? $"{Model.Tuoi} tuổi"
                                    : "-")
                            </td>
                        </tr>

                        <tr>
                            <td class="text-muted fw-semibold">Nhóm máu:</td>
                            <td>@Model.NhomMau</td>
                        </tr>

                        <tr>
                            <td class="text-muted fw-semibold">Chiều cao:</td>
                            <td>@Model.ChieuCao cm</td>
                        </tr>

                        <tr>
                            <td class="text-muted fw-semibold">Cân nặng:</td>
                            <td>@Model.CanNang kg</td>
                        </tr>

                        <tr>
                            <td class="text-muted fw-semibold">Địa chỉ:</td>
                            <td>@Model.DiaChi</td>
                        </tr>

                        <tr>
                            <td class="text-muted fw-semibold">Bệnh hiện tại:</td>
                            <td>@Model.BenhHienTai</td>
                        </tr>

                        <tr>
                            <td class="text-muted fw-semibold">Ghi chú:</td>
                            <td>@Model.GhiChu</td>
                        </tr>

                        <tr>
                            <td class="text-muted fw-semibold">Ngày tiếp nhận:</td>
                            <td>@Model.NgayTiepNhan.ToString("dd/MM/yyyy")</td>
                        </tr>

                        <tr>
                            <td class="text-muted fw-semibold">Người tạo:</td>
                            <td>@Model.NguoiTao?.HoTen</td>
                        </tr>

                    </table>
                </div>
            </div>
        </div>

        <!-- BỆNH NỀN + DỊ ỨNG + THUỐC ĐANG DÙNG -->
        <div class="col-lg-4">

            <!-- BỆNH NỀN -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-warning text-dark py-3">
                    <h6 class="mb-0">
                        <i class="fas fa-disease me-2"></i>
                        Bệnh nền (@Model.BenhNhanBenhNens.Count)
                    </h6>
                </div>

                <div class="card-body">

                    @if (!Model.BenhNhanBenhNens.Any())
                    {
                        <p class="text-muted mb-0">
                            Không có bệnh nền
                        </p>
                    }

                    @foreach (var bn in Model.BenhNhanBenhNens)
                    {
                        <div class="mb-2">
                            <strong>
                                @bn.BenhNen?.TenBenhNen
                            </strong>

                            @if (bn.NgayChanDoan.HasValue)
                            {
                                <br />

                                <small class="text-muted">
                                    Chẩn đoán:
                                    @bn.NgayChanDoan.Value.ToString("dd/MM/yyyy")
                                </small>
                            }
                        </div>
                    }

                </div>
            </div>

            <!-- DỊ ỨNG -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-danger text-white py-3">
                    <h6 class="mb-0">
                        <i class="fas fa-allergies me-2"></i>
                        Dị ứng (@Model.DiUngThuocs.Count)
                    </h6>
                </div>

                <div class="card-body">

                    @if (!Model.DiUngThuocs.Any())
                    {
                        <p class="text-muted mb-0">
                            Không có dị ứng
                        </p>
                    }

                    @foreach (var du in Model.DiUngThuocs)
                    {
                        var badgeColor =
                            du.MucDoDiUng == "Nghiêm trọng"
                            ? "bg-danger"
                            : du.MucDoDiUng == "Nặng"
                                ? "bg-warning text-dark"
                                : du.MucDoDiUng == "Trung bình"
                                    ? "bg-info"
                                    : "bg-secondary";

                        <div class="d-flex justify-content-between mb-2">
                            <span>@du.HoatChat?.TenHoatChat</span>
                            <span class="badge @badgeColor">
                                @du.MucDoDiUng
                            </span>
                        </div>
                    }

                </div>
            </div>

            <!-- THUỐC ĐANG SỬ DỤNG -->
            <div class="card border-0 shadow-sm">

                <div class="card-header bg-success text-white py-3">
                    <h6 class="mb-0">
                        <i class="fas fa-pills me-2"></i>
                        Thuốc đang sử dụng (@Model.ThuocDangSuDungs.Count)
                    </h6>
                </div>

                <div class="card-body">

                    @if (!Model.ThuocDangSuDungs.Any())
                    {
                        <p class="text-muted mb-0">
                            Chưa có thuốc đang sử dụng
                        </p>
                    }

                    @foreach (var t in Model.ThuocDangSuDungs)
                    {
                        <div class="border rounded p-2 mb-2">

                            <div class="fw-bold">
                                @t.Thuoc?.TenThuoc
                            </div>

                            <small class="text-muted d-block">
                                Liều dùng:
                                @(string.IsNullOrWhiteSpace(t.LieuDung)
                                    ? "-"
                                    : t.LieuDung)
                            </small>

                            <small class="text-muted d-block">
                                Bắt đầu:
                                @(t.NgayBatDau.HasValue
                                    ? t.NgayBatDau.Value.ToString("dd/MM/yyyy")
                                    : "-")
                            </small>

                        </div>
                    }

                </div>

            </div>

        </div>

        <!-- LỊCH SỬ ĐÁNH GIÁ -->
        <div class="col-lg-4">

            <div class="card border-0 shadow-sm">

                <div class="card-header bg-info text-white py-3 d-flex justify-content-between">

                    <h6 class="mb-0">
                        <i class="fas fa-history me-2"></i>
                        Lịch sử đánh giá (@Model.DanhGias.Count)
                    </h6>

                    <a asp-controller="DanhGia" asp-action="Create" asp-route-maBenhNhan="@Model.MaBenhNhan"
                       class="btn btn-sm btn-light text-info">
                        +
                    </a>

                </div>

                <div class="card-body p-0">

                    @if (!Model.DanhGias.Any())
                    {
                        <p class="text-muted p-3 mb-0">
                            Chưa có đánh giá
                        </p>
                    }

                    @foreach (var dg in Model.DanhGias.OrderByDescending(x => x.NgayDanhGia))
                    {
                        var score = dg.TyLePhuHop ?? 0;

                        var color =
                            score >= 80 ? "bg-success"
                            : score >= 50 ? "bg-warning"
                            : "bg-danger";

                        <div class="border-bottom p-3">

                            <div class="d-flex justify-content-between">

                                <small class="text-muted">
                                    @dg.NgayDanhGia.ToString("dd/MM/yyyy HH:mm")
                                </small>

                                <span class="badge @color">
                                    @score%
                                </span>

                            </div>

                            <small class="text-muted">
                                @dg.NguoiDanhGia?.HoTen |
                                @dg.ChiTietDanhGias.Count thuốc
                            </small>

                            <details class="mt-2">

                                <summary class="small text-primary">
                                    Xem thuốc đã đánh giá
                                </summary>

                                <div class="mt-2">

                                    @foreach (var ct in dg.ChiTietDanhGias)
                                    {
                                        <div class="border rounded p-2 mb-2">

                                            <strong>
                                                @ct.Thuoc?.TenThuoc
                                            </strong>

                                            <br />

                                            <small>
                                                Điểm phù hợp:
                                                @(ct.DiemPhuHop ?? 0)
                                            </small>

                                            @if (!string.IsNullOrWhiteSpace(ct.CanhBao))
                                            {
                                                <div class="text-danger small mt-1">
                                                    ⚠ @ct.CanhBao
                                                </div>
                                            }

                                            @if (!string.IsNullOrWhiteSpace(ct.KhuyenNghi))
                                            {
                                                <div class="text-success small mt-1">
                                                    ✓ @ct.KhuyenNghi
                                                </div>
                                            }

                                        </div>
                                    }

                                </div>

                            </details>

                            <a href="/DanhGia/KetQua/@dg.MaDanhGia" class="small">
                                Xem chi tiết →
                            </a>

                        </div>
                    }

                </div>

            </div>

        </div>

    </div>


</div>