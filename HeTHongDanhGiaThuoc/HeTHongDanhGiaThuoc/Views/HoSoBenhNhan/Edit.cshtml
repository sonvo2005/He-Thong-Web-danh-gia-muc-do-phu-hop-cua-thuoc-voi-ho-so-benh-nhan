@model HoSoBenhNhan

@{
    ViewData["Title"] = "Chỉnh Sửa Hồ Sơ Bệnh Nhân";

    var hoatChats = ViewBag.HoatChats as List<HoatChat> ?? new();
    var benhNens = ViewBag.BenhNens as List<BenhNen> ?? new();
    var thuocs = ViewBag.Thuocs as List<Thuoc> ?? new();
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary me-3">
        <i class="fas fa-arrow-left"></i>
    </a>

    <h4 class="fw-bold text-primary mb-0">
        <i class="fas fa-user-edit me-2"></i>
        Chỉnh Sửa Hồ Sơ Bệnh Nhân
    </h4>
</div>
@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">

        <ul class="mb-0">

            @foreach (var state in ViewData.ModelState)
            {
                foreach (var error in state.Value.Errors)
                {
                    <li>
                        <b>@state.Key</b> :
                        @error.ErrorMessage
                    </li>
                }
            }

        </ul>

    </div>
}
    <form asp-action="Edit" asp-route-id="@Model.MaBenhNhan" method="post">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="MaBenhNhan" />

    <div class="row g-3">

        <!-- ================= THÔNG TIN ================= -->
        <div class="col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <i class="fas fa-user me-2"></i>
                    Thông Tin Bệnh Nhân
                </div>

                <div class="card-body">

                    <div class="mb-3">
                        <label asp-for="MaDinhDanhBenhNhan" class="form-label"></label>
                        <input asp-for="MaDinhDanhBenhNhan" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="HoTen" class="form-label"></label>
                        <input asp-for="HoTen" class="form-control" />
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="GioiTinh"></label>
                            <select asp-for="GioiTinh" class="form-select">
                                <option value="">-- Chọn --</option>
                                <option>Nam</option>
                                <option>Nữ</option>
                                <option>Khác</option>
                            </select>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="NgaySinh"></label>
                            <input asp-for="NgaySinh" type="date" class="form-control" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="NhomMau"></label>
                            <select asp-for="NhomMau" class="form-select">
                                <option>A+</option>
                                <option>A-</option>
                                <option>B+</option>
                                <option>B-</option>
                                <option>AB+</option>
                                <option>AB-</option>
                                <option>O+</option>
                                <option>O-</option>
                            </select>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label asp-for="ChieuCao"></label>
                            <input asp-for="ChieuCao" class="form-control" />
                        </div>

                        <div class="col-md-4 mb-3">
                            <label asp-for="CanNang"></label>
                            <input asp-for="CanNang" class="form-control" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="DiaChi"></label>
                        <textarea asp-for="DiaChi" class="form-control"></textarea>
                    </div>

                    <div class="mb-3">
                        <label asp-for="BenhHienTai"></label>
                        <textarea asp-for="BenhHienTai" class="form-control"></textarea>
                    </div>

                    <div class="mb-3">
                        <label asp-for="GhiChu"></label>
                        <textarea asp-for="GhiChu" class="form-control"></textarea>
                    </div>

                </div>
            </div>
        </div>

        <!-- ================= BỆNH NỀN ================= -->
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 mb-3">
                <div class="card-header bg-warning d-flex justify-content-between">
                    <span><i class="fas fa-notes-medical me-2"></i>Bệnh nền</span>
                    <button type="button" class="btn btn-sm btn-dark" onclick="addBenhNen()">+</button>
                </div>

                <div class="card-body" id="benhNenContainer">

                    @if (Model.BenhNhanBenhNens != null && Model.BenhNhanBenhNens.Any())
                    {
                        foreach (var item in Model.BenhNhanBenhNens)
                        {
                            <div class="row mb-2">
                                <div class="col-7">
                                    <input name="tenBenhNens" value="@item.BenhNen?.TenBenhNen" class="form-control" />
                                </div>

                                <div class="col-4">
                                    <input type="date" name="ngayChanDoans" value="@item.NgayChanDoan?.ToString("yyyy-MM-dd")"
                                           class="form-control" />
                                </div>

                                <div class="col-1">
                                    <button type="button" class="btn btn-sm btn-danger" onclick="this.closest('.row').remove()">
                                        X
                                    </button>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p id="emptyBenhNen" class="text-muted">Chưa có bệnh nền</p>
                    }

                </div>
            </div>

            <!-- ================= DỊ ỨNG ================= -->
            <div class="card shadow-sm border-0 mb-3">
                <div class="card-header bg-danger text-white d-flex justify-content-between">
                    <span><i class="fas fa-allergies me-2"></i>Dị ứng</span>
                    <button type="button" class="btn btn-sm btn-light" onclick="addDiUng()">+</button>
                </div>

                <div class="card-body" id="diUngContainer">

                    @if (Model.DiUngThuocs != null && Model.DiUngThuocs.Any())
                    {
                        foreach (var item in Model.DiUngThuocs)
                        {
                            <div class="row mb-2">

                                <div class="col-7">
                                    <select name="maHoatChats" class="form-select">
                                        @foreach (var h in hoatChats)
                                        {
                                            <option value="@h.MaHoatChat" selected="@(h.MaHoatChat == item.MaHoatChat)">
                                                @h.TenHoatChat
                                            </option>
                                        }
                                    </select>
                                </div>

                                <div class="col-4">
                                    <select name="mucDoDiUngs" class="form-select">
                                        <option selected="@(item.MucDoDiUng == "Nhẹ")">Nhẹ</option>
                                        <option selected="@(item.MucDoDiUng == "Trung bình")">Trung bình</option>
                                        <option selected="@(item.MucDoDiUng == "Nặng")">Nặng</option>
                                        <option selected="@(item.MucDoDiUng == "Nghiêm trọng")">Nghiêm trọng</option>
                                    </select>
                                </div>

                                <div class="col-1">
                                    <button type="button" class="btn btn-sm btn-danger" onclick="this.closest('.row').remove()">
                                        X
                                    </button>
                                </div>

                            </div>
                        }
                    }
                    else
                    {
                        <p id="emptyDiUng" class="text-muted">Chưa có dị ứng</p>
                    }

                </div>
            </div>

            <!-- ================= THUỐC ================= -->
            <div class="card shadow-sm border-0">
                <div class="card-header bg-success text-white d-flex justify-content-between">
                    <span><i class="fas fa-pills me-2"></i>Thuốc đang sử dụng</span>
                    <button type="button" class="btn btn-sm btn-light" onclick="addThuocDangSuDung()">+</button>
                </div>

                <div class="card-body" id="thuocContainer">

                    @if (Model.ThuocDangSuDungs != null && Model.ThuocDangSuDungs.Any())
                    {
                        foreach (var item in Model.ThuocDangSuDungs)
                        {
                            <div class="row mb-2">

                                <div class="col-4">
                                    <select name="maThuocs" class="form-select">
                                        @foreach (var t in thuocs)
                                        {
                                            
                                                @if (t.MaThuoc == item.MaThuoc)
                                                {
                                                    <option value="@t.MaThuoc" selected>
                                                        @t.TenThuoc
                                                    </option>
                                                }
                                                else
                                                {
                                                    <option value="@t.MaThuoc">
                                                        @t.TenThuoc
                                                    </option>
                                                }
                                                @t.TenThuoc
                                            
                                        }
                                    </select>
                                </div>

                                <div class="col-4">
                                    <input name="lieuDungs" value="@item.LieuDung" class="form-control" />
                                </div>

                                <div class="col-3">
                                    <input type="date" name="ngayBatDaus" value="@item.NgayBatDau?.ToString("yyyy-MM-dd")"
                                           class="form-control" />
                                </div>

                                <div class="col-1">
                                    <button type="button" class="btn btn-sm btn-danger" onclick="this.closest('.row').remove()">
                                        X
                                    </button>
                                </div>

                            </div>
                        }
                    }
                    else
                    {
                        <p id="emptyThuoc" class="text-muted">Chưa có thuốc</p>
                    }
                 
                </div>
            </div>

        </div>
    </div>

    <div class="mt-4">
        <button type="submit" class="btn btn-primary btn-lg">
            Lưu hồ sơ
        </button>
  
</form>
@section Scripts
{
    <partial name="_ValidationScriptsPartial" />

    <script>

        // =====================================================
        // DATA FROM CONTROLLER
        // =====================================================

        const hoatChatsData = @Html.Raw(
            System.Text.Json.JsonSerializer.Serialize(
                hoatChats.Select(h => new
                {
                    maHoatChat = h.MaHoatChat,
                    tenHoatChat = h.TenHoatChat
                })
            )
        );

        const benhNensData = @Html.Raw(
            System.Text.Json.JsonSerializer.Serialize(
                benhNens.Select(b => new
                {
                    maBenhNen = b.MaBenhNen,
                    tenBenhNen = b.TenBenhNen
                })
            )
        );

        const thuocsData = @Html.Raw(
            System.Text.Json.JsonSerializer.Serialize(
                thuocs.Select(t => new
                {
                    maThuoc = t.MaThuoc,
                    tenThuoc = t.TenThuoc
                })
            )
        );

        // =====================================================
        // OPTIONS
        // =====================================================

        const hoatChatOptions = hoatChatsData
            .map(h => `<option value="${h.maHoatChat}">${h.tenHoatChat}</option>`)
            .join('');

        const benhNenOptions = benhNensData
            .map(b => `<option value="${b.tenBenhNen}">${b.tenBenhNen}</option>`)
            .join('');

        const thuocOptions = thuocsData
            .map(t => `<option value="${t.maThuoc}">${t.tenThuoc}</option>`)
            .join('');

        // =====================================================
        // REMOVE EMPTY MESSAGE
        // =====================================================

        function removeEmpty(id) {
            const el = document.getElementById(id);
            if (el) el.remove();
        }

        // =====================================================
        // THÊM BỆNH NỀN
        // =====================================================

        function addBenhNen() {

            removeEmpty("emptyBenhNen");

            const row = document.createElement("div");
            row.className = "row mb-2";

            row.innerHTML = `
                <div class="col-7">

                    <select name="tenBenhNens" class="form-select">

                        <option value="">
                            -- Chọn bệnh nền --
                        </option>

                        ${benhNenOptions}

                    </select>

                </div>

                <div class="col-4">

                    <input type="date"
                           name="ngayChanDoans"
                           class="form-control">

                </div>

                <div class="col-1">

                    <button type="button"
                            class="btn btn-danger btn-sm"
                            onclick="this.closest('.row').remove()">

                        X

                    </button>

                </div>
            `;

            document
                .getElementById("benhNenContainer")
                .appendChild(row);
        }

        // =====================================================
        // THÊM DỊ ỨNG
        // =====================================================

        function addDiUng() {

            removeEmpty("emptyDiUng");

            const row = document.createElement("div");
            row.className = "row mb-2";

            row.innerHTML = `
                <div class="col-7">

                    <select name="maHoatChats"
                            class="form-select">

                        <option value="">
                            -- Chọn hoạt chất --
                        </option>

                        ${hoatChatOptions}

                    </select>

                </div>

                <div class="col-4">

                    <select name="mucDoDiUngs"
                            class="form-select">

                        <option value="Nhẹ">Nhẹ</option>
                        <option value="Trung bình">Trung bình</option>
                        <option value="Nặng">Nặng</option>
                        <option value="Nghiêm trọng">Nghiêm trọng</option>

                    </select>

                </div>

                <div class="col-1">

                    <button type="button"
                            class="btn btn-danger btn-sm"
                            onclick="this.closest('.row').remove()">

                        X

                    </button>

                </div>
            `;

            document
                .getElementById("diUngContainer")
                .appendChild(row);
        }

        // =====================================================
        // THÊM THUỐC
        // =====================================================

        function addThuocDangSuDung() {

            removeEmpty("emptyThuoc");

            const row = document.createElement("div");
            row.className = "row mb-2";

            row.innerHTML = `
                <div class="col-4">

                    <select name="maThuocs"
                            class="form-select">

                        <option value="">
                            -- Chọn thuốc --
                        </option>

                        ${thuocOptions}

                    </select>

                </div>

                <div class="col-4">

                    <input name="lieuDungs"
                           class="form-control"
                           placeholder="Liều dùng">

                </div>

                <div class="col-3">

                    <input type="date"
                           name="ngayBatDaus"
                           class="form-control">

                </div>

                <div class="col-1">

                    <button type="button"
                            class="btn btn-danger btn-sm"
                            onclick="this.closest('.row').remove()">

                        X

                    </button>

                </div>
            `;

            document
                .getElementById("thuocContainer")
                .appendChild(row);
        }

     
       
  

    </script>
}