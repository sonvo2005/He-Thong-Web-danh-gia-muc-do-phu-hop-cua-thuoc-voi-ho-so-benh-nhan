@model IEnumerable<HoSoBenhNhan>
@{
    ViewData["Title"] = "Hồ Sơ Bệnh Nhân";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold text-primary mb-0">
        <i class="fas fa-hospital-user me-2"></i>Hồ Sơ Bệnh Nhân
    </h4>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus me-1"></i>Thêm bệnh nhân
    </a>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-3">
        <form method="get" class="d-flex gap-2">
            <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Tìm theo tên, mã định danh..." />
            <button type="submit" class="btn btn-primary px-4"><i class="fas fa-search me-1"></i>Tìm</button>
            @if (!string.IsNullOrEmpty(ViewBag.Search?.ToString()))
            {
                <a asp-action="Index" class="btn btn-outline-secondary">Xóa lọc</a>
            }
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
        <span class="text-muted small">Tổng: <strong>@ViewBag.Total</strong> bệnh nhân</span>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Mã ĐD</th>
                    <th>Họ tên</th>
                    <th>Giới tính</th>
                    <th>Ngày sinh</th>
                    <th>Ngày tiếp nhận</th>
                    <th>Người tạo</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">Không có dữ liệu</td></tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td><span class="badge bg-secondary">@item.MaDinhDanhBenhNhan</span></td>
                        <td class="fw-semibold">@item.HoTen</td>
                        <td>@(item.GioiTinh == "Nam" ? "♂ Nam" : item.GioiTinh == "Nữ" ? "♀ Nữ" : item.GioiTinh)</td>
                        <td>@item.NgaySinh?.ToString("dd/MM/yyyy")</td>
                        <td class="text-muted">@item.NgayTiepNhan.ToString("dd/MM/yyyy")</td>
                        <td class="text-muted">@item.NguoiTao?.HoTen</td>
                        <td class="text-center">

                            <!-- XEM -->
                            <a asp-action="Details" asp-route-id="@item.MaBenhNhan" class="btn btn-sm btn-outline-info"
                               title="Chi tiết">
                                <i class="fas fa-eye"></i>
                            </a>

                            <!-- SỬA -->
                            <a asp-action="Edit" asp-route-id="@item.MaBenhNhan" class="btn btn-sm btn-outline-warning"
                               title="Sửa">
                                <i class="fas fa-edit"></i>
                            </a>

                            <!-- ĐÁNH GIÁ -->
                            <a asp-controller="DanhGia" asp-action="Create" asp-route-maBenhNhan="@item.MaBenhNhan"
                               class="btn btn-sm btn-outline-primary" title="Đánh giá thuốc">
                                <i class="fas fa-clipboard-check"></i>
                            </a>

                            <!-- ================= DELETE ================= -->
                            <form asp-action="Delete" method="post" asp-route-id="@item.MaBenhNhan" style="display:inline"
                                  onsubmit="return confirm('Ngài chắc chắn muốn xóa hồ sơ này?');">

                                @Html.AntiForgeryToken()

                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa">
                                    <i class="fas fa-trash"></i>
                                </button>

                            </form>

                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if ((int)ViewBag.TotalPages > 1)
    {
        <div class="card-footer bg-white d-flex justify-content-center">
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(i == (int)ViewBag.CurrentPage ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-search="@ViewBag.Search">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>
