@{
    ViewData["Title"] = "Trang chủ";
}

<div class="row mb-4">
    <div class="col-12">
        <h4 class="fw-bold text-primary">
            <i class="fas fa-tachometer-alt me-2"></i>Tổng quan hệ thống
        </h4>
        <p class="text-muted">Chào mừng, <strong>@User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value</strong>!</p>
    </div>
</div>

<!-- Thống kê -->
<div class="row g-3 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="card stat-card border-0 shadow-sm bg-primary text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1 opacity-75">Bệnh nhân</p>
                        <h3 class="fw-bold mb-0">@ViewBag.TongBenhNhan</h3>
                    </div>
                    <i class="fas fa-hospital-user fa-2x opacity-50"></i>
                </div>
                <a href="/HoSoBenhNhan" class="text-white-50 small mt-2 d-block">Xem tất cả →</a>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card stat-card border-0 shadow-sm bg-success text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1 opacity-75">Danh mục thuốc</p>
                        <h3 class="fw-bold mb-0">@ViewBag.TongThuoc</h3>
                    </div>
                    <i class="fas fa-pills fa-2x opacity-50"></i>
                </div>
                <a href="/Thuoc" class="text-white-50 small mt-2 d-block">Xem tất cả →</a>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card stat-card border-0 shadow-sm bg-info text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1 opacity-75">Phiên đánh giá</p>
                        <h3 class="fw-bold mb-0">@ViewBag.TongDanhGia</h3>
                    </div>
                    <i class="fas fa-clipboard-check fa-2x opacity-50"></i>
                </div>
                <a href="/DanhGia" class="text-white-50 small mt-2 d-block">Xem tất cả →</a>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card stat-card border-0 shadow-sm text-white" style="background:#8b5cf6">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1 opacity-75">Tỷ lệ phù hợp TB</p>
                        <h3 class="fw-bold mb-0">@ViewBag.TrungBinhPhuHop%</h3>
                    </div>
                    <i class="fas fa-chart-pie fa-2x opacity-50"></i>
                </div>
                <small class="text-white-50 mt-2 d-block">Trung bình toàn hệ thống</small>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <!-- Đánh giá gần đây -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center py-3">
                <h6 class="fw-bold mb-0"><i class="fas fa-history me-2 text-primary"></i>Đánh giá gần đây</h6>
                <a href="/DanhGia" class="btn btn-sm btn-outline-primary">Xem tất cả</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Bệnh nhân</th>
                                <th>Người đánh giá</th>
                                <th>Ngày</th>
                                <th>Tỷ lệ phù hợp</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.DanhGiaGanDay != null)
                            {
                                foreach (var dg in ViewBag.DanhGiaGanDay)
                                {
                                    decimal tyle = dg.TyLePhuHop ?? 0;
                                    string badgeClass = tyle >= 80 ? "bg-success" : tyle >= 50 ? "bg-warning" : "bg-danger";
                                    <tr>
                                        <td class="fw-semibold">@dg.HoSoBenhNhan?.HoTen</td>
                                        <td class="text-muted">@dg.NguoiDanhGia?.HoTen</td>
                                        <td class="text-muted">@dg.NgayDanhGia.ToString("dd/MM/yyyy")</td>
                                        <td><span class="badge @badgeClass">@tyle%</span></td>
                                        <td>
                                            <a href="/DanhGia/KetQua/@dg.MaDanhGia" class="btn btn-xs btn-outline-primary btn-sm">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Thao tác nhanh -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 py-3">
                <h6 class="fw-bold mb-0"><i class="fas fa-bolt me-2 text-warning"></i>Thao tác nhanh</h6>
            </div>
            <div class="card-body d-flex flex-column gap-2">
                <a href="/DanhGia/Create" class="btn btn-primary">
                    <i class="fas fa-plus-circle me-2"></i>Tạo đánh giá mới
                </a>
                <a href="/HoSoBenhNhan/Create" class="btn btn-outline-primary">
                    <i class="fas fa-user-plus me-2"></i>Thêm bệnh nhân
                </a>
                <a href="/Thuoc/Create" class="btn btn-outline-success">
                    <i class="fas fa-pills me-2"></i>Thêm thuốc mới
                </a>
                @if (User.IsInRole("Admin"))
                {
                    <a href="/Admin/TuongTacThuoc" class="btn btn-outline-warning">
                        <i class="fas fa-exclamation-triangle me-2"></i>Quản lý tương tác
                    </a>
                }
            </div>
        </div>
    </div>
</div>
