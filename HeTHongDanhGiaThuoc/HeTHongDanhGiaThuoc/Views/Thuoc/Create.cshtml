@model Thuoc
@{
    ViewData["Title"] = "Thêm Thuốc";
    var hoatChats = ViewBag.HoatChats as List<HoatChat>;
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary me-3"><i class="fas fa-arrow-left"></i></a>
    <h4 class="fw-bold text-primary mb-0"><i class="fas fa-pills me-2"></i>Thêm Thuốc Mới</h4>
</div>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div class="row g-3">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-primary text-white py-3">
                    <h6 class="mb-0"><i class="fas fa-info-circle me-2"></i>Thông tin cơ bản</h6>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="TenThuoc" class="form-label fw-semibold"></label>
                        <input asp-for="TenThuoc" class="form-control" placeholder="Tên thuốc (INN hoặc generic)" />
                        <span asp-validation-for="TenThuoc" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="TenBietDuoc" class="form-label fw-semibold"></label>
                        <input asp-for="TenBietDuoc" class="form-control" placeholder="Tên thương mại/biệt dược" />
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label asp-for="DangBaoChe" class="form-label fw-semibold"></label>
                            <select asp-for="DangBaoChe" class="form-select">
                                <option value="">-- Chọn --</option>
                                <option>Viên nén</option>
                                <option>Viên nang</option>
                                <option>Dung dịch uống</option>
                                <option>Dung dịch tiêm</option>
                                <option>Bột pha tiêm</option>
                                <option>Kem bôi</option>
                                <option>Nhỏ mắt</option>
                                <option>Siro</option>
                                <option>Khác</option>
                            </select>
                        </div>
                        <div class="col-6 mb-3">
                            <label asp-for="TinhTrangThuoc" class="form-label fw-semibold"></label>
                            <select asp-for="TinhTrangThuoc" class="form-select">
                                <option value="Hoạt động">Hoạt động</option>
                                <option value="Ngưng sử dụng">Ngưng sử dụng</option>
                                <option value="Tạm ngưng">Tạm ngưng</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="LieuDungChuan" class="form-label fw-semibold"></label>
                        <input asp-for="LieuDungChuan" class="form-control" placeholder="VD: 500mg, 2 lần/ngày" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="MoTaChiTiet" class="form-label fw-semibold"></label>
                        <textarea asp-for="MoTaChiTiet" class="form-control" rows="3"
                                  placeholder="Mô tả chi tiết về thuốc..."></textarea>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <!-- Hoạt chất -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-info text-white py-3 d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="fas fa-atom me-2"></i>Hoạt chất</h6>
                    <button type="button" class="btn btn-sm btn-light text-info" onclick="themHoatChat()">
                        <i class="fas fa-plus"></i> Thêm
                    </button>
                </div>
                <div class="card-body" id="dsHoatChat">
                    <p class="text-muted small" id="emptyHC">Chưa có hoạt chất nào</p>
                </div>
            </div>

            <!-- Chống chỉ định -->
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-danger text-white py-3 d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="fas fa-ban me-2"></i>Chống chỉ định</h6>
                    <button type="button" class="btn btn-sm btn-light text-danger" onclick="themChongChiDinh()">
                        <i class="fas fa-plus"></i> Thêm
                    </button>
                </div>
                <div class="card-body" id="dsCCD">
                    <p class="text-muted small" id="emptyCCD">Chưa có chống chỉ định nào</p>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3 d-flex gap-2">
        <button type="submit" class="btn btn-primary px-4">
            <i class="fas fa-save me-2"></i>Lưu thuốc
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
    </div>
</form>

@section Scripts {
<script>
const hoatChatOptions = `@if (hoatChats != null) {
    foreach (var hc in hoatChats)
    { @("<option value='" + hc.MaHoatChat + "'>" + hc.TenHoatChat + "</option>") }
}`;

function themHoatChat() {
    document.getElementById('emptyHC').style.display = 'none';
    const container = document.getElementById('dsHoatChat');
    const div = document.createElement('div');
    div.className = 'border rounded p-2 mb-2 bg-light';
    div.innerHTML = `
        <div class="row g-2 align-items-center">
            <div class="col-7">
                <select name="maHoatChats" class="form-select form-select-sm">
                    <option value="0">-- Chọn hoạt chất --</option>
                    ${hoatChatOptions}
                </select>
            </div>
            <div class="col-4">
                <input type="text" name="hamLuongs" class="form-control form-control-sm" placeholder="Hàm lượng (VD: 500mg)" />
            </div>
            <div class="col-1">
                <button type="button" class="btn btn-sm btn-outline-danger" onclick="this.closest('div.border').remove()">
                    <i class="fas fa-times"></i>
                </button>
            </div>
        </div>`;
    container.appendChild(div);
}

function themChongChiDinh() {
    document.getElementById('emptyCCD').style.display = 'none';
    const container = document.getElementById('dsCCD');
    const div = document.createElement('div');
    div.className = 'border rounded p-2 mb-2 bg-light';
    div.innerHTML = `
        <div class="row g-2 align-items-center">
            <div class="col-6">
                <input type="text" name="tenBenhChongChiDinhs" class="form-control form-control-sm"
                       placeholder="Tên bệnh chống chỉ định" required />
            </div>
            <div class="col-5">
                <input type="text" name="ghiChuChongChiDinhs" class="form-control form-control-sm"
                       placeholder="Ghi chú (tùy chọn)" />
            </div>
            <div class="col-1">
                <button type="button" class="btn btn-sm btn-outline-danger" onclick="this.closest('div.border').remove()">
                    <i class="fas fa-times"></i>
                </button>
            </div>
        </div>`;
    container.appendChild(div);
}
</script>
}
