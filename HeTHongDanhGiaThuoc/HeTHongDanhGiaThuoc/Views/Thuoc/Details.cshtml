@model Thuoc
@{
    ViewData["Title"] = Model.TenThuoc;
    var allTuongTac = Model.TuongTacA.Concat(Model.TuongTacB).ToList();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div class="d-flex align-items-center">
        <a asp-action="Index" class="btn btn-outline-secondary me-3"><i class="fas fa-arrow-left"></i></a>
        <h4 class="fw-bold text-primary mb-0">
            <i class="fas fa-pills me-2"></i>@Model.TenThuoc
        </h4>
    </div>
    @if (User.IsInRole("Admin") || User.IsInRole("Dược sĩ"))
    {
        <a asp-action="Edit" asp-route-id="@Model.MaThuoc" class="btn btn-warning">
            <i class="fas fa-edit me-1"></i>Chỉnh sửa
        </a>
    }
</div>

<div class="row g-3">
    <!-- Thông tin cơ bản -->
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-primary text-white py-3">
                <h6 class="mb-0"><i class="fas fa-info-circle me-2"></i>Thông tin thuốc</h6>
            </div>
            <div class="card-body">
                <table class="table table-sm table-borderless mb-0">
                    <tr>
                        <td class="text-muted fw-semibold" style="width:40%">Tên thuốc:</td>
                        <td><strong>@Model.TenThuoc</strong></td>
                    </tr>
                    <tr>
                        <td class="text-muted fw-semibold">Biệt dược:</td>
                        <td>@Model.TenBietDuoc</td>
                    </tr>
                    <tr>
                        <td class="text-muted fw-semibold">Dạng bào chế:</td>
                        <td><span class="badge bg-light text-dark border">@Model.DangBaoChe</span></td>
                    </tr>
                    <tr>
                        <td class="text-muted fw-semibold">Liều dùng chuẩn:</td>
                        <td>@Model.LieuDungChuan</td>
                    </tr>
                    <tr>
                        <td class="text-muted fw-semibold">Tình trạng:</td>
                        <td>
                            <span class="badge @(Model.TinhTrangThuoc == "Hoạt động" ? "bg-success" : "bg-secondary")">
                                @Model.TinhTrangThuoc
                            </span>
                        </td>
                    </tr>
                </table>
                @if (!string.IsNullOrEmpty(Model.MoTaChiTiet))
                {
                    <hr />
                    <p class="text-muted small mb-0">@Model.MoTaChiTiet</p>
                }
            </div>
        </div>

        <!-- Hoạt chất -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-info text-white py-3">
                <h6 class="mb-0"><i class="fas fa-atom me-2"></i>Hoạt chất (@Model.ThuocHoatChats.Count)</h6>
            </div>
            <div class="card-body">
                @if (!Model.ThuocHoatChats.Any())
                {
                    <p class="text-muted mb-0">Chưa có thông tin hoạt chất</p>
                }
                @foreach (var thc in Model.ThuocHoatChats)
                {
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="fw-semibold">@thc.HoatChat?.TenHoatChat</span>
                        @if (!string.IsNullOrEmpty(thc.HamLuong))
                        {
                            <span class="badge bg-light text-dark border">@thc.HamLuong</span>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Chống chỉ định & tương tác -->
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-danger text-white py-3">
                <h6 class="mb-0"><i class="fas fa-ban me-2"></i>Chống chỉ định (@Model.ChongChiDinhs.Count)</h6>
            </div>
            <div class="card-body">
                @if (!Model.ChongChiDinhs.Any())
                {
                    <p class="text-muted mb-0">Không có chống chỉ định ghi nhận</p>
                }
                @foreach (var ccd in Model.ChongChiDinhs)
                {
                    <div class="alert alert-danger alert-sm py-2 px-3 mb-2">
                        <strong>@ccd.TenBenhChongChiDinh</strong>
                        @if (!string.IsNullOrEmpty(ccd.GhiChu))
                        {
                            <br /><small>@ccd.GhiChu</small>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-warning text-dark py-3">
                <h6 class="mb-0"><i class="fas fa-exchange-alt me-2"></i>Tương tác thuốc (@allTuongTac.Count)</h6>
            </div>
            <div class="card-body">
                @if (!allTuongTac.Any())
                {
                    <p class="text-muted mb-0">Không có tương tác thuốc ghi nhận</p>
                }
                @foreach (var tt in allTuongTac)
                {
                    var thuocKhac = tt.MaThuoc_A == Model.MaThuoc ? tt.ThuocB : tt.ThuocA;
                    string severityClass = (tt.MucDoNghiemTrong?.ToLower().Contains("nghiêm") == true ||
                                           tt.MucDoNghiemTrong?.ToLower().Contains("cao") == true)
                                           ? "danger" : "warning";
                    <div class="alert alert-@severityClass py-2 px-3 mb-2">
                        <div class="d-flex justify-content-between">
                            <strong><i class="fas fa-pills me-1"></i>@thuocKhac?.TenThuoc</strong>
                            <span class="badge bg-@severityClass">@tt.MucDoNghiemTrong</span>
                        </div>
                        @if (!string.IsNullOrEmpty(tt.MoTaTuongTac))
                        {
                            <small>@tt.MoTaTuongTac</small>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
