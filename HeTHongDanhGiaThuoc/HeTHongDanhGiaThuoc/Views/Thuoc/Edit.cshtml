@model Thuoc
@using HeTHongDanhGiaThuoc.Models

@{
    ViewData["Title"] = "Chỉnh Sửa Thuốc";

    var hoatChats = ViewBag.HoatChats as List<HoatChat> ?? new();
    var benhNens = ViewBag.BenhNens as List<BenhNen> ?? new();
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Details"
       asp-route-id="@Model.MaThuoc"
       class="btn btn-outline-secondary me-3">
        <i class="fas fa-arrow-left"></i>
    </a>

    <h4 class="fw-bold text-primary mb-0">
        <i class="fas fa-edit me-2"></i>
        Chỉnh Sửa Thuốc: @Model.TenThuoc
    </h4>
</div>

<form asp-action="Edit" method="post">

    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="MaThuoc" />

    <div class="row g-3">

        <!-- THÔNG TIN CƠ BẢN -->
        <div class="col-lg-6">

            <div class="card border-0 shadow-sm">

                <div class="card-header bg-warning text-dark py-3">
                    <h6 class="mb-0">
                        <i class="fas fa-info-circle me-2"></i>
                        Thông Tin Cơ Bản
                    </h6>
                </div>

                <div class="card-body">

                    <div class="mb-3">
                        <label asp-for="TenThuoc" class="form-label fw-semibold"></label>
                        <input asp-for="TenThuoc" class="form-control" />
                        <span asp-validation-for="TenThuoc" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="TenBietDuoc" class="form-label fw-semibold"></label>
                        <input asp-for="TenBietDuoc" class="form-control" />
                    </div>

                    <div class="row">

                        <div class="col-md-6 mb-3">
                            <label asp-for="DangBaoChe" class="form-label fw-semibold"></label>

                            <select asp-for="DangBaoChe" class="form-select">

                                <option value="">-- Chọn --</option>

                                <option>Viên nén</option>
                                <option>Viên nang</option>
                                <option>Dung dịch uống</option>
                                <option>Dung dịch tiêm</option>
                                <option>Bột pha tiêm</option>
                                <option>Kem bôi</option>
                                <option>Nhỏ mắt</option>
                                <option>Siro</option>

                            </select>
                        </div>

                        <div class="col-md-6 mb-3">

                            <label asp-for="TinhTrangThuoc"
                                   class="form-label fw-semibold"></label>

                            <select asp-for="TinhTrangThuoc"
                                    class="form-select">

                                <option value="Hoạt động">Hoạt động</option>
                                <option value="Ngưng sử dụng">Ngưng sử dụng</option>
                                <option value="Tạm ngưng">Tạm ngưng</option>

                            </select>

                        </div>

                    </div>

                    <div class="mb-3">
                        <label asp-for="LieuDungChuan"
                               class="form-label fw-semibold"></label>

                        <input asp-for="LieuDungChuan"
                               class="form-control" />
                    </div>
                    <div class="row g-2 mb-3">

                        <div class="col-md-6">
                            <label asp-for="TuoiToiThieu" class="form-label fw-semibold"></label>
                            <input asp-for="TuoiToiThieu" class="form-control" type="number" min="0" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="TuoiToiDa" class="form-label fw-semibold"></label>
                            <input asp-for="TuoiToiDa" class="form-control" type="number" min="0" />
                        </div>

                    </div>

                    <div class="row g-2 mb-3">

                        <div class="col-md-6">
                            <label asp-for="CanNangToiThieu" class="form-label fw-semibold"></label>
                            <input asp-for="CanNangToiThieu" class="form-control" type="number" step="0.1" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="CanNangToiDa" class="form-label fw-semibold"></label>
                            <input asp-for="CanNangToiDa" class="form-control" type="number" step="0.1" />
                        </div>

                    </div>

                    <div class="row g-2 mb-3">

                        <div class="col-md-6">
                            <label asp-for="LieuToiThieuMg" class="form-label fw-semibold"></label>
                            <input asp-for="LieuToiThieuMg" class="form-control" type="number" step="0.1" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="LieuToiDaMg" class="form-label fw-semibold"></label>
                            <input asp-for="LieuToiDaMg" class="form-control" type="number" step="0.1" />
                        </div>

                    </div>

                    <div class="row g-2 mb-3">

                        <div class="col-md-6">
                            <label asp-for="LieuKhuyenNghiMg" class="form-label fw-semibold"></label>
                            <input asp-for="LieuKhuyenNghiMg" class="form-control" type="number" step="0.1" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="TanSuatToiDaMoiNgay" class="form-label fw-semibold"></label>
                            <input asp-for="TanSuatToiDaMoiNgay" class="form-control" type="number" />
                        </div>

                    </div>
                    <div class="mb-3">
                        <label asp-for="MoTaChiTiet"
                               class="form-label fw-semibold"></label>

                        <textarea asp-for="MoTaChiTiet"
                                  rows="4"
                                  class="form-control"></textarea>
                    </div>

                </div>

            </div>

        </div>

        <!-- THÔNG TIN PHỤ -->
        <div class="col-lg-6">

            <!-- HOẠT CHẤT -->
            <div class="card border-0 shadow-sm mb-3">

                <div class="card-header bg-info text-white py-3 d-flex justify-content-between align-items-center">

                    <h6 class="mb-0">
                        <i class="fas fa-flask me-2"></i>
                        Hoạt Chất
                    </h6>

                    <button type="button"
                            class="btn btn-sm btn-light"
                            onclick="themHoatChat()">
                        +
                    </button>

                </div>

                <div class="card-body" id="dsHoatChat">

                    @if (!Model.ThuocHoatChats.Any())
                    {
                        <p id="emptyHC" class="text-muted">
                            Chưa có hoạt chất
                        </p>
                    }

                    @foreach (var thc in Model.ThuocHoatChats)
                    {
                        <div class="border rounded p-2 mb-2 bg-light">

                            <div class="row g-2">

                                <div class="col-7">

                                    <select name="maHoatChats"
                                            class="form-select form-select-sm">

                                        <option value="0">
                                            -- Chọn hoạt chất --
                                        </option>

                                        @foreach (var hc in hoatChats)
                                        {
                                            @if (hc.MaHoatChat == thc.MaHoatChat)
                                            {
                                                <option value="@hc.MaHoatChat" selected>
                                                    @hc.TenHoatChat
                                                </option>
                                            }
                                            else
                                            {
                                                <option value="@hc.MaHoatChat">
                                                    @hc.TenHoatChat
                                                </option>
                                            }
                                        }

                                    </select>

                                </div>

                                <div class="col-4">

                                    <input name="hamLuongs"
                                           value="@thc.HamLuong"
                                           class="form-control form-control-sm"
                                           placeholder="Hàm lượng" />

                                </div>

                                <div class="col-1">

                                    <button type="button"
                                            class="btn btn-sm btn-danger"
                                            onclick="this.closest('.border').remove()">
                                        ×
                                    </button>

                                </div>

                            </div>

                        </div>
                    }

                </div>

            </div>

            <!-- CHỐNG CHỈ ĐỊNH -->
            <div class="card border-0 shadow-sm">

                <div class="card-header bg-danger text-white py-3 d-flex justify-content-between align-items-center">

                    <h6 class="mb-0">
                        <i class="fas fa-ban me-2"></i>
                        Chống Chỉ Định
                    </h6>

                    <button type="button"
                            class="btn btn-sm btn-light"
                            onclick="themChongChiDinh()">
                        +
                    </button>

                </div>

                <div class="card-body" id="dsCCD">

                    @if (!Model.ChongChiDinhs.Any())
                    {
                        <p id="emptyCCD" class="text-muted">
                            Chưa có chống chỉ định
                        </p>
                    }

                    @foreach (var ccd in Model.ChongChiDinhs)
                    {
                        <div class="border rounded p-2 mb-2 bg-light">

                            <div class="row g-2">

                                <div class="col-6">

                                    <select name="maBenhNens"
                                            class="form-select form-select-sm">

                                        <option value="0">
                                            -- Chọn bệnh nền --
                                        </option>

                                        @foreach (var bn in benhNens)
                                        {
                                            @if (bn.MaBenhNen == ccd.MaBenhNen)
                                            {
                                                <option value="@bn.MaBenhNen" selected>
                                                    @bn.TenBenhNen
                                                </option>
                                            }
                                            else
                                            {
                                                <option value="@bn.MaBenhNen">
                                                    @bn.TenBenhNen
                                                </option>
                                            }
                                        }

                                    </select>

                                </div>

                                <div class="col-5">

                                    <input name="mucDoNguyHiem"
                                           value="@ccd.MucDoNguyHiem"
                                           class="form-control form-control-sm"
                                           placeholder="Mức độ nguy hiểm" />

                                </div>

                                <div class="col-1">

                                    <button type="button"
                                            class="btn btn-sm btn-danger"
                                            onclick="this.closest('.border').remove()">
                                        ×
                                    </button>

                                </div>

                            </div>

                        </div>
                    }

                </div>

            </div>

        </div>

    </div>

    <div class="mt-4">

        <button type="submit"
                class="btn btn-warning">
            <i class="fas fa-save me-2"></i>
            Lưu Thay Đổi
        </button>

        <a asp-action="Details"
           asp-route-id="@Model.MaThuoc"
           class="btn btn-secondary">
            Hủy
        </a>

    </div>

</form>
