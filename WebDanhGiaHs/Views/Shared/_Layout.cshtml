<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebDanhGiaHs</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebDanhGiaHs.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
            body {
                background-color: #f4f6f9;
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                padding-bottom: 70px;
                /* Tránh bị thanh footer che khuất nội dung dưới cùng */
            }

            .nav-tabs .nav-link {
                border: none;
                color: #6c757d;
                font-weight: 500;
                padding: 0.5rem 1rem;
                border-bottom: 3px solid transparent;
            }

            .nav-tabs .nav-link:hover {
                border-color: transparent;
                color: #0d6efd;
            }

            .nav-tabs .nav-link.active {
                color: #0d6efd;
                background-color: transparent;
                border-bottom: 3px solid #0d6efd;
                font-weight: bold;
            }
    </style>
</head>

<body>
    <header class="bg-white border-bottom shadow-sm sticky-top mb-4">
        <div class="container-fluid px-4">
            <div class="d-flex justify-content-between align-items-center py-2">
                <div class="d-flex align-items-center">
                    <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3 shadow-sm"
                         style="width: 44px; height: 44px; min-width: 44px;">
                        <img src="data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='white'><path d='M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-2 10h-4v4h-2v-4H7v-2h4V7h2v4h4v2z'/></svg>"
                             alt="Medical Logo" style="width: 26px; height: 26px;" />
                    </div>
                    <div>
                        <h5 class="mb-0 fw-bold text-dark text-uppercase"
                            style="font-size: 1.05rem; letter-spacing: 0.5px;">
                            Hệ thống đánh giá mức độ phù hợp của thuốc
                        </h5>
                        <small class="text-muted" style="font-size: 0.75rem;">Hỗ trợ quyết định lâm sàng & Kê đơn an
                            toàn</small>
                        </div>
                    </div>

                    <div class="d-flex align-items-center">
                        <div class="input-group shadow-sm" style="width: 320px;">
                            <span class="input-group-text bg-white border-end-0 text-muted"><i
                                class="bi bi-search"></i></span>
                                <input type="text" class="form-control form-control-sm border-start-0 ps-0"
                                       placeholder="Mã bệnh nhân / ID hồ sơ...">
                                <button class="btn btn-primary btn-sm px-3" type="button">Tìm</button>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center border-top pt-1">
                        <ul class="nav nav-tabs border-0 small">
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")"
                                   asp-controller="Home" asp-action="Index">
                                    <i class="bi bi-person-lines-fill me-1"></i> BM01: Tiếp Nhận Bệnh Nhân
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "MucLucThuoc" ? "active" : "")"
                                   asp-controller="Home" asp-action="MucLucThuoc">
                                    <i class="bi bi-sliders me-1"></i> BM02: Đặc Tính Thuốc
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "KetQuaDanhGia" ? "active" : "")"
                                   asp-controller="Home" asp-action="KetQuaDanhGia">
                                    <i class="bi bi-check-circle-fill me-1"></i> BM03: Kết Quả Đánh Giá
                                </a>
                            </li>
                        </ul>
                        <span class="badge bg-light text-secondary border small fw-normal py-1 px-2 mb-1">Phiên bản Demo
                            1.0</span>
                        </div>
                    </div>
                </header>

                <div class="container-fluid px-4">
                    <main role="main" class="pb-5">
                        @RenderBody()
                    </main>
                </div>

                

                <script src="~/lib/jquery/dist/jquery.min.js"></script>
                <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
                <script src="~/js/site.js" asp-append-version="true"></script>
                @await RenderSectionAsync("Scripts", required: false)
            </body>

        </html>